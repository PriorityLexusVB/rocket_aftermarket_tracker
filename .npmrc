# Do not auto-install peerDependencies. The only peer that was being
# auto-installed is `next` (an unused peer of @dhiwise/component-tagger, a
# build-time Vite plugin). `next` is imported nowhere in src/** and dragged in
# ~13 high/critical advisories that failed CI's pnpm-audit gate. Every real
# peer (react, react-dom, redux, vite, tailwind) is an explicit dependency,
# so disabling auto-install-peers drops only `next`.
auto-install-peers=false
